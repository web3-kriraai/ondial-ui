# Public URLs (safe for the browser bundle)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Contentful (server-only — do NOT prefix with NEXT_PUBLIC_)
# Use .env.local for local dev + `npm run build` (Next.js does not load .env.development during builds).
CONTENTFUL_SPACE_ID=
CONTENTFUL_GRAPHQL_TOKEN=
CONTENTFUL_ENVIRONMENT=master
